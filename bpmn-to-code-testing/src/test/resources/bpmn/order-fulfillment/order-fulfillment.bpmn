<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_OrderFulfillment"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="orderFulfillment" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OrderReceived" name="Order received">
      <bpmn:outgoing>Flow_ToPayment</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:callActivity id="CallActivity_ProcessPayment" name="Process payment" calledElement="paymentProcessing">
      <bpmn:incoming>Flow_ToPayment</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCompleted</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="EndEvent_OrderCompleted" name="Order completed">
      <bpmn:incoming>Flow_ToCompleted</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToPayment" sourceRef="StartEvent_OrderReceived" targetRef="CallActivity_ProcessPayment" />
    <bpmn:sequenceFlow id="Flow_ToCompleted" sourceRef="CallActivity_ProcessPayment" targetRef="EndEvent_OrderCompleted" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="orderFulfillment">
      <bpmndi:BPMNShape id="StartEvent_OrderReceived_di" bpmnElement="StartEvent_OrderReceived">
        <dc:Bounds x="152" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CallActivity_ProcessPayment_di" bpmnElement="CallActivity_ProcessPayment">
        <dc:Bounds x="240" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_OrderCompleted_di" bpmnElement="EndEvent_OrderCompleted">
        <dc:Bounds x="392" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_ToPayment_di" bpmnElement="Flow_ToPayment">
        <di:waypoint x="188" y="100" />
        <di:waypoint x="240" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCompleted_di" bpmnElement="Flow_ToCompleted">
        <di:waypoint x="340" y="100" />
        <di:waypoint x="392" y="100" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
